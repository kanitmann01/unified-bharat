# NDAP Open API — same value as the portal "API_Key" query parameter (never commit real keys).

# Base URL for Get API (QA vs production). Example QA:
# https://loadqa.ndapapi.com/v1/openapi
NDAP_BASE_URL=https://loadqa.ndapapi.com/v1/openapi
NDAP_API_KEY=
# Copy this file to .env, fill values, then from the project root run:
#   python test/ndap/fetch_all.py
# One source only:
#   python test/ndap/fetch_all.py --only csr_district
# Custom config path (must stay under this project folder):
#   python test/ndap/fetch_all.py --config test/ndap/sources.yaml
